# Copy to config.local next to start.bat (optional).
# If you omit this file, the live database is Treasurer.db in the project folder.

# Optional — live database somewhere else on this laptop only:
# TREASURER_DATABASE=D:\TreasurerData\Treasurer.db

# Optional — mirrored backup file or folder (Settings can also set this):
# TREASURER_BACKUP_DATABASE=C:\Users\YourName\Documents\Treasurer Backups\Treasurer.backup.db

# Optional — set to 1 so only one app instance uses the database at a time (recommended):
# TREASURER_RUNTIME_LOCK=1
