# Copy to `config.local` next to start.bat (optional). Not committed.

# Default if you omit this file: live DB is LodgeOffice.db in this folder (legacy Treasurer.db still used if present);
# mirrored backup defaults under Documents/Lodge Office Backups or legacy Treasurer Backups — see start.bat.

# TREASURER_DATABASE=C:\Users\You\Documents\Code\lodge-office\LodgeOffice.db
# TREASURER_BACKUP_DATABASE=C:\Users\You\Documents\Code\lodge-office\backups\LodgeOffice.backup.db
# Optional aliases: LODGE_OFFICE_DATABASE, LODGE_OFFICE_BACKUP_DATABASE

# Optional — for a DB on a network share, set TREASURER_DATABASE to your UNC path.

# Optional — single-instance lock (recommended on one laptop):
# TREASURER_RUNTIME_LOCK=1
