# Copy to .env on the server (never commit .env).
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=

# SQLite files inside the app container (default paths match docker-compose volume)
TREASURER_DATABASE=/data/Treasurer.db
TREASURER_BACKUP_DATABASE=/data/Treasurer.backup.db

# Optional: single-instance guard used on Windows laptops; leave off or 0 for server
# TREASURER_RUNTIME_LOCK=0

# Optional: minimum password length (default 8 so shared first login “password” is valid). Set to 10 for stricter policy.
# TREASURER_PASSWORD_MIN_LENGTH=10

# Optional: pre-fill “Initial password” on Add user (default: password; padded with 0s only if min length is above 8)
# TREASURER_DEFAULT_INITIAL_PASSWORD=password

# Optional: create first Admin user when the users table is empty (password length must meet TREASURER_PASSWORD_MIN_LENGTH)
# TREASURER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# TREASURER_BOOTSTRAP_ADMIN_PASSWORD=

# Optional SMTP for forgot-password emails (see docs/Runbook.md)
# MAIL_SERVER=
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=

# Caddy site address. Use :80 for HTTP-only (e.g. testing by IP). Use a real DNS name for HTTPS.
SITE_ADDRESS=:80
