# Copy to .env on the server (never commit .env).
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=

# SQLite files inside the app container (default paths match docker-compose volume)
TREASURER_DATABASE=/data/Treasurer.db
TREASURER_BACKUP_DATABASE=/data/Treasurer.backup.db

# Optional: single-instance guard used on Windows laptops; leave off or 0 for server
# TREASURER_RUNTIME_LOCK=0

# Caddy site address. Use :80 for HTTP-only (e.g. testing by IP). Use a real DNS name for HTTPS.
SITE_ADDRESS=:80
